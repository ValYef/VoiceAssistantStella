<Window 
    x:Class="VoiceAssistant.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceAssistant"
    xmlns:classes="using:VoiceAssistant.Components.Sphere"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Voice Assistant Stella"
    >

    <Grid Background="#FF1E1E1E">

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <!-- header -->
            <RowDefinition Height="Auto"/>
            <!-- answer -->
            <RowDefinition Height="Auto"/>
            <!-- commands -->
            <RowDefinition Height="*"/>
            <!-- main -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                Spacing="30"
                VerticalAlignment="Center"
                Margin="0,0,0,20">

            <TextBlock x:Name="volumeTextBlock"
                   Text="Гучність: 0.00"
                   FontSize="12"
                   Foreground="White"/>

            <TextBlock x:Name="intentTextBlock"
                   Text="Намір: -"
                   FontSize="12"
                   Foreground="White"/>

            <TextBlock x:Name="confidenceTextBlock"
                   Text="Впевненість: -"
                   FontSize="12"
                   Foreground="White"/>
        </StackPanel>

        <!-- ANSWER -->
        <TextBlock Grid.Row="1"
               x:Name="answerTextBlock"
               Text="Тут з'являтимуться відповіді"
               FontSize="18"
               Foreground="White"
               TextWrapping="Wrap"
               TextAlignment="Center"
               HorizontalAlignment="Center"
               MaxWidth="700"
               Margin="0,10,0,10"/>

        <!-- COMMAND -->
        <TextBlock Grid.Row="2"
               x:Name="commandOutputTextBlock"
               Text=""
               FontSize="16"
               Foreground="LightGray"
               TextAlignment="Center"
               HorizontalAlignment="Center"
               MaxWidth="700"
               Margin="0,5,0,10"/>

        <!-- MAIN -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- СФЕРА -->
            <classes:SphereControl x:Name="animatedSphere"
                               Width="600"
                               Height="600"
                               Margin="0,20,20,0"/>

            <!-- ПРАВАЯ ЧАСТЬ -->
            <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="1">
                    <Button x:Name="myButton"
                        Click="myButton_Click"
                        Content="Почати прослуховування"
                        MinWidth="200"
                        HorizontalAlignment="Center"/>
                </ScrollViewer>
                
                <ScrollViewer Grid.Row="2">
                    <TextBlock x:Name="myTextBlock"
                           TextWrapping="Wrap"
                           Foreground="White"
                           TextAlignment="Center"/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
